# Braze REST API Configuration
# Copy this file to .env and populate with your values.
# On Vercel: set these in Project → Settings → Environment Variables.
# NEVER commit a populated .env file.

# SERVER-ONLY SECRET — never add to window.__APP_CONFIG__ or expose client-side.
# Used exclusively by the serverless proxy: api/braze/[...path].js
BRAZE_API_KEY=your-rest-api-key-here

# Public cluster URL — safe to expose in window.__APP_CONFIG__ as it is not sensitive.
# Also used server-side by the proxy to construct the Braze request URL.
# Presence of this value activates Live Mode in the browser (isLiveMode() check).
BRAZE_REST_ENDPOINT=https://rest.iad-01.braze.com
